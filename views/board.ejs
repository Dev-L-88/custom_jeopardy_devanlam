<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/board.css">
  <title>Jeopardy Board - <%= roomCode %></title>
  <script src="/socket.io/socket.io.js"></script>
</head>
<body>
  <h1 id="game-title" style="margin: 5px 0;">Loading Jeopardy Game...</h1>
  <h2 style="font-size: 16px; margin: 0 0 10px 0;">Room Code: <span style="color: #00f5ff;"><%= roomCode %></span></h2>

  <div id="game-board-container" class="board-grid" style="display: grid; width: 100%; gap: 15px;"></div>

  <div class="scoreboard-section">
    <h3 class="scoreboard-title">Active Competitors Scoreboard</h3>
    <div id="scoreboard-players-wrapper" class="players-score-flex">
      <span style="color: #555555; font-style: italic;">Waiting for contestants to sync...</span>
    </div>
  </div>

  <div id="clue-display-overlay" class="clue-overlay">
    <div class="clue-overlay-content">
      <div id="active-prompt-text" class="overlay-prompt"></div>
      
      <div id="overlay-image-wrapper" style="display: none; margin: 20px auto; text-align: center;">
        <img id="overlay-display-img" src="" style="max-height: 350px; max-width: 80%; border: 3px solid #ffffff; border-radius: 8px; box-shadow: 0px 4px 15px rgba(0,0,0,0.5);" alt="Clue Asset">
      </div>

      <button id="reveal-answer-btn" onclick="revealClueAnswer()" class="btn btn-cyan" style="font-size: 24px; padding: 15px 35px;">
        Reveal Answer
      </button>
      <div id="active-answer-text" class="overlay-answer" style="display: none;"></div>
      <br><br>
      <button onclick="closeClueOverlay()" class="btn btn-danger" style="font-size: 18px; padding: 10px 25px;">
        Back to Board
      </button>
    </div>
  </div>

  <script>
    const roomCode = "<%= roomCode %>";
    let activeClueData = null;

    const socket = io({ transports: ['websocket'] });

    socket.emit('joinRoom', { roomCode: roomCode, username: "GAME_BOARD_DISPLAY" });

    socket.on('playerDataUpdate', (playersArray) => {
      updateLiveScores(playersArray);
    });

    socket.on('buzzerLocked', (buzzQueue) => {
      const leadingBuzzerName = buzzQueue[0];
      console.log(`Live active room buzz leader: ${leadingBuzzerName}`);

      const overlayPrompt = document.getElementById('active-prompt-text');
      const existingIndicator = document.getElementById('buzz-indicator');
      
      if (overlayPrompt && !existingIndicator) {
        const indicator = document.createElement('div');
        indicator.id = 'buzz-indicator';
        indicator.style.fontSize = '28px';
        indicator.style.color = '#ffff00';
        indicator.style.marginTop = '20px';
        indicator.style.fontWeight = 'bold';
        indicator.innerText = `${leadingBuzzerName} BUZZED IN FIRST!`;
        
        overlayPrompt.after(indicator);
      }
    });

    socket.on('buzzerResetSignal', () => {
      const existingIndicator = document.getElementById('buzz-indicator');
      if (existingIndicator) {
        existingIndicator.remove();
      }
    });

    document.addEventListener("DOMContentLoaded", async () => {
      try {
        const response = await fetch(`/api/get-room-board/${roomCode}`);
        const data = await response.json();

        if (data.success) {
          renderLiveBoard(data.boardData);
        } else {
          document.getElementById('game-title').innerText = "Failed to load board data.";
        }
      } catch (err) {
        console.error(err);
        document.getElementById('game-title').innerText = "Connection error loading board.";
      }
    });

    function renderLiveBoard(boardData) {
      document.getElementById('game-title').innerText = boardData.title || "Jeopardy Match";
      const container = document.getElementById("game-board-container");
      if (!container) return;
      container.innerHTML = "";

      const colsCount = boardData.colsCount || (boardData.categories ? boardData.categories.length : 5);
      const rowsCount = boardData.rowsCount || (boardData.categories && boardData.categories[0] && boardData.categories[0].clues ? boardData.categories[0].clues.length : 5);

      container.style.gridTemplateColumns = `repeat(${colsCount}, 1fr)`;

      boardData.categories.forEach(cat => {
        const header = document.createElement("div");
        header.className = "board-header";
        header.innerText = cat.name || "Category";
        container.appendChild(header);
      });

      for (let row = 0; row < rowsCount; row++) {
        for (let col = 0; col < colsCount; col++) {
          const targetCategory = boardData.categories[col];
          const clue = (targetCategory && targetCategory.clues) ? targetCategory.clues[row] : null;
          
          const clueBox = document.createElement("div");
          clueBox.className = "board-clue";
          
          let boxText = "---";
          if (clue) {
            boxText = clue.value !== undefined ? `$${clue.value}` : `$${(row + 1) * 200}`;
          }
          clueBox.innerText = boxText;

          if (clue && (clue.question || clue.answer)) {
            clueBox.onclick = () => {
              if (clueBox.classList.contains('clicked')) return;
              clueBox.classList.add('clicked');
              launchClueOverlay(clue);
            };
          } else {
            clueBox.classList.add('clicked');
          }

          container.appendChild(clueBox);
        }
      }
    }

    function updateLiveScores(players) {
      const wrapper = document.getElementById('scoreboard-players-wrapper');
      wrapper.innerHTML = ""; 

      if (!players || players.length === 0) {
        wrapper.innerHTML = `<span style="color: #555555; font-style: italic;">No contestants inside the lobby room.</span>`;
        return;
      }

      players.forEach(player => {
        if (player.username === "GAME_BOARD_DISPLAY" || player.username === "HOST_CONSOLE") return;

        const scoreCard = document.createElement('div');
        scoreCard.className = 'player-score-card';
        scoreCard.innerHTML = `
          <p class="player-score-name">${player.username}</p>
          <p class="player-score-points">${player.score ?? 0} pts</p>
        `;
        wrapper.appendChild(scoreCard);
      });
    }

    function launchClueOverlay(clue) {
      activeClueData = clue;
      
      const promptTextElement = document.getElementById('active-prompt-text');
      const imgWrapper = document.getElementById('overlay-image-wrapper');
      const displayImg = document.getElementById('overlay-display-img');
      
      promptTextElement.innerHTML = "";
      
      const questionText = document.createElement('div');
      questionText.innerText = clue.question || "No prompt written.";
      promptTextElement.appendChild(questionText);
      
      if (clue.image && clue.image.trim() !== "") {
        displayImg.src = clue.image;
        displayImg.style.borderColor = "#ffffff"; 
        imgWrapper.style.display = 'block';
      } else {
        displayImg.src = "";
        imgWrapper.style.display = 'none';
      }

      document.getElementById('active-answer-text').innerText = clue.answer ? `Correct response: ${clue.answer}` : "No answer written.";
      document.getElementById('active-answer-text').style.display = 'none';
      document.getElementById('reveal-answer-btn').style.display = 'inline-block';
      
      const existingIndicator = document.getElementById('buzz-indicator');
      if (existingIndicator) existingIndicator.remove();

      document.getElementById('clue-display-overlay').style.display = 'flex';
    }

    function revealClueAnswer() {
      document.getElementById('reveal-answer-btn').style.display = 'none';
      document.getElementById('active-answer-text').style.display = 'block';

      if (activeClueData && activeClueData.answerImage && activeClueData.answerImage.trim() !== "") {
        const imgWrapper = document.getElementById('overlay-image-wrapper');
        const displayImg = document.getElementById('overlay-display-img');

        displayImg.src = activeClueData.answerImage;
        displayImg.style.borderColor = "#ffff00"; 
        imgWrapper.style.display = 'block';
      }
    }

    function closeClueOverlay() {
      activeClueData = null;
      document.getElementById('clue-display-overlay').style.display = 'none';
    }
  </script>
</body>
</html>