<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/creator.css">
  <title>Custom Jeopardy Website Thing</title>
</head>
<body>
  <h1>🎂 Custom Jeopardy Website Thing!! 🎂</h1>
  
  <div style="margin-top: 50px;">
    <a href="/creator" class="btn">Create Board</a>
    <button onclick="openEditModal()" class="btn">Edit Board</button>
    
    <hr>
    
    <h3>Select a Saved Jeopardy Board to Launch:</h3>
    
    <select id="board-selector" class="input-field" style="margin-bottom: 15px; display: inline-block;">
      <option value="default">Loading your saved boards...</option>
    </select>
    
    <br>
    <button onclick="launchSelectedGame()" class="btn btn-cyan">Host a Game</button>
  </div>

  <div id="edit-modal" class="modal-overlay">
    <div class="modal-content">
      <h2>Select Board to Edit</h2>
      <p style="color: #00f5ff;">Click any board configuration below to open it in the editor workspace:</p>
      
      <ul id="modal-board-list" class="modal-list"></ul>
      
      <button onclick="closeEditModal()" class="btn btn-danger" style="margin-top: 10px;">Cancel</button>
    </div>
  </div>

  <script>
    // --- FIXED: Automatically populate dropdown from localStorage on load ---
    document.addEventListener("DOMContentLoaded", () => {
      populateBoardDropdown();
    });

    function populateBoardDropdown() {
      const selector = document.getElementById('board-selector');
      selector.innerHTML = ""; // Clear loader text
      
      // Pull boards directly out of browser local memory
      const localBoards = JSON.parse(localStorage.getItem("jeopardy_boards") || "{}");
      const boardKeys = Object.keys(localBoards);

      if (boardKeys.length === 0) {
        const option = document.createElement('option');
        option.value = "default";
        option.innerText = "No boards found (Go create one!)";
        selector.appendChild(option);
        return;
      }

      // Add each saved board configuration directly to the dropdown list
      boardKeys.forEach(id => {
        const option = document.createElement('option');
        option.value = id;
        option.innerText = localBoards[id].title;
        selector.appendChild(option);
      });
    }

    // --- FIXED: Handles extracting data from localStorage and launching a dynamic server game session ---
    async function launchSelectedGame() {
      const selectedId = document.getElementById('board-selector').value;
      
      if (selectedId === 'default') {
        alert("Please create a board first before attempting to host a game room session!");
        return;
      }

      const localBoards = JSON.parse(localStorage.getItem("jeopardy_boards") || "{}");
      const selectedBoard = localBoards[selectedId];

      // Pass the entire custom board object blueprint straight up to the Socket server state engine
      const response = await fetch('/api/create-room', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ boardData: selectedBoard }) 
      });
      
      const data = await response.json();
      if (data.roomCode) {
        window.location.href = `/host/${data.roomCode}`;
      } else {
        alert("Failed to initialize active game room session on server.");
      }
    }

    // --- MODAL POPUP LOGIC ENGAGING ---
    function openEditModal() {
      const selector = document.getElementById('board-selector');
      
      if (selector.value === 'default') {
        alert("You don't have any saved boards to edit yet! Click 'Create Board' to make your first one.");
        return;
      }

      const listContainer = document.getElementById('modal-board-list');
      listContainer.innerHTML = ""; // Wipe past links before loading fresh arrays

      // Convert dropdown values into interactive modal selection layout buttons
      const optionsArray = Array.from(selector.options);
      optionsArray.forEach((option) => {
        const listItem = document.createElement('li');
        
        listItem.innerHTML = `
          <button class="modal-item-btn" onclick="navigateToEditor('${option.value}')">
            ${option.text}
          </button>
        `;
        listContainer.appendChild(listItem);
      });

      // Change CSS display state from none to flex to show overlay
      document.getElementById('edit-modal').style.display = 'flex';
    }

    function closeEditModal() {
      document.getElementById('edit-modal').style.display = 'none';
    }

    function navigateToEditor(boardId) {
      window.location.href = `/creator?boardId=${boardId}`;
    }
  </script>
</body>
</html>